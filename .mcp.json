{
  "name": "health-check-ai-mcp",
  "description": "health-check-ai-mcp \u2014 Built by [MEOK AI Labs](https://meok.ai)",
  "version": "1.0.0",
  "tools": [
    {
      "name": "check_url",
      "description": "Check if a URL is responding. Returns status code, latency, headers.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "timeout": {
            "type": "integer"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    {
      "name": "check_multiple",
      "description": "Check multiple URLs (comma-separated). Returns status for each.",
      "parameters": {
        "type": "object",
        "properties": {
          "urls": {
            "type": "string"
          }
        },
        "required": [
          "urls"
        ]
      }
    },
    {
      "name": "check_ssl",
      "description": "Check SSL certificate validity and expiration.",
      "parameters": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          }
        },
        "required": [
          "domain"
        ]
      }
    },
    {
      "name": "monitor_uptime",
      "description": "Get uptime estimate based on response pattern.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    }
  ]
}
